# ==========================================
# 1. CẤU HÌNH TELEGRAM BOT
# ==========================================
# Token lấy từ BotFather
BOT_TOKEN=nhập_token_của_bot_vào_đây


# Chat ID của bạn (để nhận thông báo nổ đơn)
OWNER_CHAT_ID=nhập_chat_id_của_bạn_vào_đây


# ==========================================
# 2. CẤU HÌNH TRÍ TUỆ NHÂN TẠO (GROQ)
# ==========================================
# API Key lấy từ console.groq.com
GROQ_API_KEY=nhập_api_key_groq_vào_đây


# ==========================================
# 3. CẤU HÌNH CỔNG THANH TOÁN PAYOS
# ==========================================
# Lấy tại mục: Cài đặt -> Tích hợp trên trang quản trị PayOS
PAYOS_CLIENT_ID=nhập_client_id_vào_đây
PAYOS_API_KEY=nhập_api_key_vào_đây
PAYOS_CHECKSUM_KEY=nhập_checksum_key_vào_đây


# ==========================================
# 4. CẤU HÌNH DATABASE
# ==========================================
# Chuỗi kết nối từ MongoDB Atlas (Nhớ thay thế <password> bằng mật khẩu thật)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.../tiemtrasua?retryWrites=true&w=majority


# ==========================================
# 5. CẤU HÌNH SERVER (Tùy chọn)
# ==========================================
PORT=3000